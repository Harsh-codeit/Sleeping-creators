# ─── Backend URL ──────────────────────────────────────────────────────────────
# Local dev: point to your running FastAPI server
# Production: leave empty — all /api calls are same-origin (served by FastAPI)
REACT_APP_BACKEND_URL=http://localhost:8000


# ─── Creatomate (optional — for video preview tokens) ────────────────────────

# Token for Creatomate embed/preview in the UI (if needed for previews)
REACT_APP_CREATOMATE_PREVIEW_TOKEN=

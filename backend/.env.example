# ─── Core (required — app won't start without these) ──────────────────────────

MONGO_URL=mongodb://localhost:27017
DB_NAME=sleeping-creators

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-to-a-long-random-string

# Your public domain — used for OAuth callbacks and carousel image URLs
# Local dev: http://localhost:8000
# Production: https://yourdomain.com
FRONTEND_URL=http://localhost:8000


# ─── AI Content Generation (required) ─────────────────────────────────────────

ANTHROPIC_API_KEY=sk-ant-api03-...


# ─── Bundle.social — Unified Publishing (required for publishing) ──────────────
# Get from: bundle.social → Dashboard → API Keys
BUNDLE_API_KEY=pk_live_...
# Get from: bundle.social → Organization → Webhooks (after registering webhook URL)
BUNDLE_WEBHOOK_SECRET=wh_...


# ─── Storage — pick ONE backend ───────────────────────────────────────────────

STORAGE_BACKEND=r2

# Option A: Cloudflare R2 (recommended)
R2_ACCOUNT_ID=abc123...
R2_ACCESS_KEY_ID=...
R2_SECRET_ACCESS_KEY=...
R2_BUCKET_NAME=sleeping-creators
R2_PUBLIC_URL=https://pub-abc123.r2.dev

# Option B: MinIO (self-hosted)
# STORAGE_BACKEND=minio
# MINIO_ENDPOINT=http://localhost:9000
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin
# MINIO_BUCKET=sleeping-creators-media
# MINIO_PUBLIC_URL=http://localhost:9000/sleeping-creators-media
# MINIO_REGION=us-east-1


# ─── Redis — required for Celery video worker ──────────────────────────────────

REDIS_URL=redis://localhost:6379/0


# ─── Google (optional — for Sheets sync and Drive video clips) ─────────────────
# Create at: console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=123456789-abc.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...


# ─── Apify (optional — for competitor scraping and Instagram trend data) ────────
# Get from: apify.com → Settings → Integrations → API tokens
APIFY_API_KEY=apify_api_...


# ─── Meta / Instagram OAuth (legacy — now replaced by Bundle.social) ───────────
# Only needed if you want the old direct Instagram/Facebook connect buttons to work.
# Bundle.social handles platform auth for publishing — these are no longer required.
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
# Optional second Meta app (rate limit workaround)
INSTAGRAM_APP_ID_2=
INSTAGRAM_APP_SECRET_2=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=


# ─── Performance tuning (optional) ────────────────────────────────────────────

# Number of concurrent Playwright browsers for carousel rendering (default: 2)
CAROUSEL_RENDER_CONCURRENCY=2


# ─── Creatomate (optional — for AI video generation) ──────────────────────────

# Get from: creatomate.com → Account Settings → API Keys
CREATOMATE_API_KEY=
CREATOMATE_WEBHOOK_SECRET=

# Full public URL for webhook callbacks (e.g., https://app.example.com/webhooks/creatomate)
CREATOMATE_WEBHOOK_URL=

# Rate limiting: max renders per 10 seconds (default: 30)
CREATOMATE_RATE_LIMIT_PER_10S=30

# Number of concurrent video renders (default: 8)
CREATOMATE_WORKER_CONCURRENCY=8
